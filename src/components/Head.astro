---
// Replace Starlight's Default Head: render the route.head array ourselves so
// we can filter out og:locale (Starlight emits ISO-639-1 like "ja"; OG spec
// wants underscore form like "ja_JP") and then emit a corrected og:locale plus
// the tags Starlight does not emit at all (og:image*, twitter:image*,
// article:*, x-default hreflang, custom JSON-LD).

const SITE = 'https://llmoframework.com';
const OG_IMAGE = `${SITE}/og-image.png`;
const PROJECT_GENESIS = '2026-03-07';

const route = (Astro.locals as any).starlightRoute;
const entry = route?.entry;
const data = entry?.data ?? {};
const slug = entry?.slug ?? '';

const pageUrl = new URL(Astro.url.pathname, SITE).href;

const pubDateRaw = data.pubDate as Date | string | undefined;
const datePublished = pubDateRaw instanceof Date
  ? pubDateRaw.toISOString().slice(0, 10)
  : (typeof pubDateRaw === 'string' ? pubDateRaw.slice(0, 10) : PROJECT_GENESIS);

const lastUpdatedRaw = route?.lastUpdated;
const dateModified = lastUpdatedRaw instanceof Date
  ? lastUpdatedRaw.toISOString().slice(0, 10)
  : (typeof lastUpdatedRaw === 'string' ? lastUpdatedRaw.slice(0, 10) : datePublished);

const localeKey = (route?.locale as string | undefined) ?? '';

// Fallback detection: if the URL says /<lang>/ but the resolved entry.id
// doesn't start with that lang directory, Starlight is serving the English
// fallback. In that case the visible body language is English, so the OG
// locale and JSON-LD inLanguage signals must reflect English — not the URL
// language. Without this, AI crawlers see <html lang="zh-CN"> on a page
// that is actually English content (Coherence Signal violation in the very
// site that defines Coherence Signals).
const entryId = (entry?.id as string | undefined) ?? '';
// A localized homepage (ja/index.mdx) resolves to entry.id === "ja" (bare
// locale, no trailing "/index"), so the startsWith check alone misclassifies a
// genuinely translated homepage as a fallback. Treat entryId === localeKey as a
// real localized page too.
const isFallback = Boolean(localeKey)
  && entryId !== localeKey
  && !entryId.startsWith(`${localeKey}/`);

const langTag = isFallback
  ? 'en'
  : (route?.lang as string | undefined)
    ?? (localeKey === 'pt' ? 'pt-BR' : localeKey === 'zh' ? 'zh-CN' : (localeKey || 'en'));

const title = (data.title as string | undefined) ?? 'LLMO Framework';
const description = (data.description as string | undefined)
  ?? 'The open standard for making your content discoverable by AI — ChatGPT, Claude, Gemini, Perplexity.';

// OG spec wants language_TERRITORY (underscore). Map BCP-47 -> OG locale.
const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  ja: 'ja_JP',
  'zh-CN': 'zh_CN',
  ko: 'ko_KR',
  de: 'de_DE',
  fr: 'fr_FR',
  es: 'es_ES',
  'pt-BR': 'pt_BR',
};
const ogLocale = ogLocaleMap[langTag] ?? 'en_US';
const ogLocaleAlternates = Object.values(ogLocaleMap).filter((v) => v !== ogLocale);

// Articles get TechArticle schema and article:* meta. The site root and the
// 404 page are NOT articles — they describe the site as a whole or signal an
// error, not a single document.
const NON_ARTICLE_SLUGS = new Set(['', 'index', '404']);
const isArticle = !NON_ARTICLE_SLUGS.has(slug);

// x-default hreflang: link to the English (root locale) equivalent of the current page.
const localePrefixes = ['ja', 'zh', 'ko', 'de', 'fr', 'es', 'pt'];
let pathWithoutLocale = Astro.url.pathname;
for (const prefix of localePrefixes) {
  if (pathWithoutLocale === `/${prefix}/` || pathWithoutLocale === `/${prefix}`) {
    pathWithoutLocale = '/';
    break;
  }
  if (pathWithoutLocale.startsWith(`/${prefix}/`)) {
    pathWithoutLocale = pathWithoutLocale.slice(prefix.length + 1);
    break;
  }
}
const xDefaultUrl = new URL(pathWithoutLocale, SITE).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  url: pageUrl,
  inLanguage: langTag,
  datePublished,
  dateModified,
  author: {
    '@type': 'Person',
    name: 'Ken Imoto',
    url: 'https://kenimoto.dev',
    sameAs: [
      'https://github.com/kenimo49',
      'https://www.linkedin.com/in/kenimo49',
      'https://x.com/kenimo49',
    ],
  },
  publisher: {
    '@type': 'Organization',
    name: 'Propel-Lab',
    url: 'https://propel-lab.co.jp',
    logo: {
      '@type': 'ImageObject',
      url: OG_IMAGE,
    },
  },
  image: OG_IMAGE,
  isPartOf: {
    '@type': 'WebSite',
    name: 'LLMO Framework',
    url: SITE,
  },
  mainEntityOfPage: pageUrl,
};

// Filter Starlight's computed head array: drop og:locale (we re-emit it in
// the OG-spec underscore form below) and og:image:alt placeholders if any.
type HeadTag = { tag: string; attrs?: Record<string, string | undefined>; content?: string };
const headTags: HeadTag[] = (route?.head ?? []).filter((t: HeadTag) => {
  const attrs = t.attrs ?? {};
  if (t.tag === 'meta' && attrs.property === 'og:locale') return false;
  return true;
});
---

{headTags.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<!-- Google Analytics (GA4) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-365LMYNSYQ"></script>
<!-- is:inline is load-bearing: without it Astro bundles this as type="module",
     scoping (and minifying) `gtag` so it never reaches window.gtag — the funnel
     listener below then no-ops on its typeof guard. -->
<script is:inline>
  // 内部トラフィック除外: 自動化ブラウザ / ローカル / ?internal=1 オプトイン端末を計測しない
  (function () {
    try { if (new URLSearchParams(location.search).get('internal') === '1') { localStorage.setItem('llmoframework_internal', '1'); } } catch (e) {}
    var optedOut = false;
    try { optedOut = localStorage.getItem('llmoframework_internal') === '1'; } catch (e) {}
    if (navigator.webdriver || optedOut || /^(localhost|127\.|192\.168\.|iris-pc)/.test(location.hostname)) {
      window['ga-disable-G-365LMYNSYQ'] = true;
    }
  })();
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-365LMYNSYQ');
</script>

<!-- GA4 funnel events: outbound + key CTA clicks (mark as key events in GA4 console) -->
<script is:inline>
  document.addEventListener('click', function (e) {
    var a = e.target && e.target.closest && e.target.closest('a[href]');
    if (!a || typeof gtag !== 'function') return;
    var external = a.host && a.host !== location.host;
    if (external) {
      gtag('event', 'outbound_click', {
        link_url: a.href,
        link_domain: a.host,
        link_text: (a.textContent || '').trim().slice(0, 100),
      });
    }
    // GitHub clicks are already captured by outbound_click (filter link_domain=github.com in GA4).
    if (/^\/(?:[a-z]{2}\/)?guide\/quickstart\/?$/.test(a.pathname)) gtag('event', 'cta_quickstart');
  }, true);
</script>

<!-- Open Graph: locale (underscore form) + alternates + image -->
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((loc) => <meta property="og:locale:alternate" content={loc} />)}
<meta property="og:image" content={OG_IMAGE} />
<meta property="og:image:secure_url" content={OG_IMAGE} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="LLMO Framework — The open standard for AI discoverability" />
{isArticle && <meta property="article:published_time" content={datePublished} />}
{isArticle && <meta property="article:modified_time" content={dateModified} />}
{isArticle && <meta property="article:author" content="https://kenimoto.dev" />}

<!-- Twitter Card extras (Starlight emits twitter:card by default) -->
<meta name="twitter:site" content="@kenimo49" />
<meta name="twitter:creator" content="@kenimo49" />
<meta name="twitter:image" content={OG_IMAGE} />
<meta name="twitter:image:alt" content="LLMO Framework — The open standard for AI discoverability" />

<!-- Fallback pages serve English content at a localized URL (no translation
     exists yet). Self-canonicalizing them would create duplicate English copies
     across /de/, /fr/, /es/... that split authority for terms like "llmo" and
     violate the Coherence Signal this site defines. noindex,follow keeps them
     crawlable but out of the index; when a real translation is added the page
     stops being a fallback and this tag disappears automatically. -->
{isFallback && <meta name="robots" content="noindex,follow" />}

<!-- x-default hreflang complements Starlight's per-locale hreflang tags -->
<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

<!-- Per-page TechArticle JSON-LD with datePublished / dateModified -->
{isArticle && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
)}
