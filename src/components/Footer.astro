---
/**
 * Custom Footer that augments Starlight's Default with the framework version.
 * The version is read from src/data/version.ts (single source of truth).
 */
import Default from '@astrojs/starlight/components/Footer.astro';
import { VERSION } from '../data/version';

const route = (Astro.locals as any).starlightRoute;
const localeKey = (route?.locale as string | undefined) ?? '';
const changelogHref = localeKey === 'ja' ? '/ja/changelog/' : '/changelog/';
const label = localeKey === 'ja' ? '変更履歴' : 'Changelog';
---

<Default><slot /></Default>

<div class="initiative-footer">
  <div class="initiative-line">
    <span class="initiative-label">Open LLMO Research Initiative</span>
  </div>
  <div class="founder-line">
    Founded and maintained by <a href="https://kenimoto.dev" class="founder-link">Ken Imoto</a>
  </div>
  <div class="version-line">
    <span class="version-label">LLMO Framework</span>
    <a href={changelogHref} class="version-link">v{VERSION} · {label}</a>
  </div>
</div>

<style>
  .initiative-footer {
    margin: 2rem auto 1.5rem;
    padding: 0 var(--sl-content-pad-x);
    max-width: var(--sl-content-width);
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-text-accent);
    opacity: 0.8;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .initiative-label {
    font-family: var(--sl-font-mono);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .founder-line {
    font-size: var(--sl-text-xs);
    opacity: 0.85;
  }
  .founder-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed currentColor;
  }
  .founder-link:hover {
    opacity: 1;
    border-bottom-style: solid;
  }
  .version-line {
    margin-top: 0.25rem;
    opacity: 0.7;
  }
  .version-label {
    font-family: var(--sl-font-mono);
    margin-right: 0.5em;
  }
  .version-link {
    font-family: var(--sl-font-mono);
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed currentColor;
  }
  .version-link:hover {
    opacity: 1;
    border-bottom-style: solid;
  }
</style>
